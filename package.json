{
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite --host 0.0.0.0",
    "format": "bunx prettier --write \"README.md\" \"package.json\" \"vite.config.mjs\" \".github/**/*.yml\" \"website/**/*.{html,css,js}\"",
    "format:check": "bunx prettier --check \"README.md\" \"package.json\" \"vite.config.mjs\" \".github/**/*.yml\" \"website/**/*.{html,css,js}\"",
    "lint": "bun run format:check && bun run build"
  },
  "devDependencies": {
    "vite": "^8.0.14"
  }
}
